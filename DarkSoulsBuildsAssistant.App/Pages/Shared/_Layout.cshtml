<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Database Editor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { darkbg: '#121212', panelbg: '#1A1A1D', goldborder: '#C89B64', goldtext: '#D4AF37' },
                    fontFamily: { serif: ['"EB Garamond"', 'serif'], sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body { background-color: #121212; }
        .panel { background-color: #1A1A1D;
                 border: 1px solid #C89B64;
                 border-radius: 0.375rem;
               }
        .image-area {
            background-image: url("/Images/img.png");
            background-position: center center;
            background-size: cover;
            background-repeat: no-repeat;
            width: 100%;
            min-height: 400px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="font-sans h-screen flex overflow-hidden">

<aside class="w-64 flex-shrink-0 panel border-t-0 border-l-0 border-b-0 rounded-none flex flex-col h-full overflow-y-auto z-10">
    <div class="p-4 bg-black/20 mt-20 flex items-center gap-3">
        <i class="fa-solid fa-border-all text-gray-400 text-xl"></i>
        <div>
            <h3 class="text-gray-200 font-serif text-lg font-semibold leading-tight"><a asp-page="/Admin/Index">Dashboard</a></h3>
        </div>
    </div>
    <nav class="flex-1 px-4 py-6 space-y-6">
        <a asp-page="/Admin/Users" class="flex items-center gap-3 @(ViewData["ActivePage"]?.ToString() == "Users" ? "text-goldtext border-l-2 border-goldborder pl-2 -ml-[10px]" : "text-gray-400 hover:text-gray-200 transition")">
            <i class="fa-solid fa-users w-6 text-center text-xl"></i>
            <span class="@(ViewData["ActivePage"]?.ToString() == "Users" ? "font-bold" : "font-medium")">User Accounts</span>
        </a>
        <div>
            <div class="flex items-center gap-3 @(ViewData["ActivePage"]?.ToString() == "EldenRing" ? "text-goldtext" : "text-gray-400") mb-3 hover:text-gray-200 transition">
                <i class="fa-solid fa-khanda w-6 text-center"></i><span class="font-medium">Game Editor</span>
            </div>
            <div class="ml-9 flex flex-col gap-3 text-sm text-gray-500">
                <a href="#" class="hover:text-gray-300">DS1</a>
                <a href="#" class="hover:text-gray-300">DS2</a>
                <a href="#" class="hover:text-gray-300">DS3</a>
                <a asp-page="/Admin/EldenRing" class="@(ViewData["ActivePage"]?.ToString() == "EldenRing" ? "text-goldtext border-l-2 border-goldborder pl-2 -ml-[10px]" : "hover:text-gray-300")">Elden Ring</a>
            </div>
        </div>
    </nav>
</aside>

<main class="flex-1 flex flex-col h-full relative @(ViewData["ShowImageArea"] != null && (bool)ViewData["ShowImageArea"] ? "image-area" : "")">
    @if (ViewData["ShowImageArea"] != null && (bool)ViewData["ShowImageArea"])
    {
        <div class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-orange-900/20 to-transparent pointer-events-none"></div>
    }

    <header class="h-20 panel border-x-0 border-t-0 rounded-none flex items-center justify-between px-8 z-10">
        <div class="flex items-center gap-4">
            <h1 class="text-2xl font-serif text-gray-200">
                @if (ViewData["ActivePage"]?.ToString() == "Users")
                {
                    <i class="fa-solid fa-users-gear mr-3 text-goldtext"></i>@:User Management
                }
                else
                {
                    @ViewData["Title"]
                }
            </h1>
        </div>
        <div class="flex items-center gap-6 text-gray-400">
            <div class="flex items-center gap-2 border border-goldborder rounded-full py-1 pl-1 pr-3 bg-black/30">
                <div class="w-8 h-8 rounded-full bg-gray-600 flex items-center justify-center text-white"><i class="fa-solid fa-user"></i></div>
                <span class="text-sm font-medium">Admin</span>
            </div>
        </div>
    </header>

    <div class="flex-1 overflow-y-auto p-8 z-10 relative">
        @RenderBody()
    </div>
</main>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>