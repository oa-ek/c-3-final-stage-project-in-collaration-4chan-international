@page
@model DarkSoulsBuildsAssistant.App.Pages.Admin.EldenRingModel
@{
ViewData["Title"] = "Elden Ring: Database Editor";
ViewData["ActivePage"] = "EldenRing";
ViewData["ShowImageArea"] = true;

// Локальна функція для генерації CSS-класів активної/неактивної вкладки
string GetTabClass(string tabName) =>
Model.CurrentCategory == tabName
? "flex items-center space-x-3 px-6 py-3 text-goldtext font-semibold bg-white/10 border-b-2 border-goldborder rounded-t-md transition"
: "flex items-center space-x-3 px-6 py-3 text-gray-400 hover:text-gray-200 hover:bg-white/5 rounded-t-md transition";
}

<div class="flex justify-between items-end mb-6">
    <div class="flex gap-2 rounded-t-lg px-2 pt-2 shadow-lg border-x border-t border-goldborder/80 bg-panelbg">
        <a href="?category=armor" class="@GetTabClass("armor")">
            <img src="/images/armor.jpg" class="w-6 h-6 rounded-lg object-cover" alt="Armor">
            <span>Armor</span>
        </a>

        <a href="?category=weapons" class="@GetTabClass("weapons")">
            <svg width="25" height="25" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                <rect width="32" height="32" fill="url(#pattern0_16_14)"/>
                <defs>
                    <pattern id="pattern0_16_14" patternContentUnits="objectBoundingBox" width="1" height="1">
                        <use xlink:href="#image0_16_14" transform="scale(0.03125)"/>
                    </pattern>
                    <image id="image0_16_14" width="25" height="25" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
                </defs>
            </svg>
            <span>Weapons</span>
        </a>

        <a href="?category=talismans" class="@GetTabClass("talismans")">
            <img src="/images/talisman.jpg" class="w-6 h-6 rounded-lg object-cover" alt="Talisman">
            <span>Talismans</span>
        </a>

        <a href="?category=spells" class="@GetTabClass("spells")">
            <svg xmlns="http://www.w3.org/2000/svg" height="20pt" preserveAspectRatio="xMidYMid meet" viewBox="0 0 1886 1920" width="20pt">
