            </svg>
            <span>Spells</span>
        </a>
    </div>

    @if (Model.CurrentCategory == "armor")
    {
    <button onclick="openModal('addArmorModal')" class="bg-goldborder hover:bg-yellow-600 text-black font-semibold py-2 px-4 rounded transition flex items-center gap-2 ml-4 flex-shrink-0">
        <i class="fa-solid fa-plus"></i> Add Armor
    </button>
    }
    else if (Model.CurrentCategory == "weapons")
    {
    <button onclick="openModal('addWeaponModal')" class="bg-goldborder hover:bg-yellow-600 text-black font-semibold py-2 px-4 rounded transition flex items-center gap-2 ml-4 flex-shrink-0">
        <i class="fa-solid fa-plus"></i> Add Weapon
    </button>
    }
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

    @foreach (var item in Model.Equipments)
    {
    string iconClass;
    if (item.SlotName != null &&
    (
    item.SlotName.ToLower().Contains("lefthand") ||
    item.SlotName.ToLower().Contains("righthand")
    )
    )
    {
    iconClass = "fa-khanda";
    }
    else
    {
    iconClass = "fa-shield";
    }
    <div class="bg-panelbg border border-gray-800 rounded-lg p-5 flex flex-col hover:border-gray-600 transition shadow-lg relative group">
        <div class="w-full h-40 bg-black/40 rounded border border-gray-800 mb-4 overflow-hidden flex items-center justify-center">
            <img src="@item.IconPath" asp-append-version="true" class="h-full object-contain opacity-100 group-hover:opacity-100 transition duration-300" alt="Item Image">
        </div>

        <div class="flex justify-between items-start mb-4">
            <h3 class="text-lg font-serif text-goldtext font-semibold pr-6">@item.Name</h3>
            <i class="fa-solid @iconClass text-gray-500 text-xl"></i>
        </div>

        <div class="space-y-2 text-sm mb-4">
            <div class="flex justify-between items-center">
                <span class="text-gray-400">Тип</span>
                <span class="text-gray-200 bg-white/5 px-2 py-0.5 rounded">@item.SlotName</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-gray-400">Вага</span>
                <span class="font-mono text-gray-200">@item.Weight</span>
            </div>

            @if (item.Poise.HasValue)
            {
            <div class="flex justify-between items-center">
                <span class="text-gray-400 font-semibold">Баланс (Poise)</span>
                <span class="font-mono text-goldtext font-bold">@item.Poise</span>
            </div>
            }
        </div>

        <div class="mt-auto pt-3 border-t border-gray-800 flex justify-end gap-4 items-center">
            @if (Model.CurrentCategory == "armor")
            {
            <button type="button"
                    onclick="editArmor(@item.Id, '@item.Name', '@item.IconPath', @(item.Weight ?? 0), @(item.Poise ?? 0))"
                    class="text-blue-400 hover:text-blue-300 transition" title="Edit">
                <i class="fa-solid fa-pen-to-square"></i>
            </button>
            }
            else if (Model.CurrentCategory == "weapons")
            {
            <button type="button"
                    onclick="editWeapon(@item.Id, '@item.Name', '@item.IconPath', @(item.Weight ?? 0), @(item.Damage ?? 0), @(item.ReqStrength ?? 0), @(item.ReqDexterity ?? 0), @(item.ReqIntelligence ?? 0), @(item.ReqFaith ?? 0))"
                    class="text-blue-400 hover:text-blue-300 transition" title="Edit">
                <i class="fa-solid fa-pen-to-square"></i>
            </button>
            }

            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" asp-route-category="@Model.CurrentCategory" class="inline m-0 p-0">
                <button type="submit" class="text-red-500 hover:text-red-400 transition" title="Delete" onclick="return confirm('Are you sure you want to delete this item?');">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </form>
        </div>
    </div>
    }

    @if (!Model.Equipments.Any())
    {
    <div class="col-span-full p-8 text-center text-gray-500 bg-white/5 rounded-lg border border-dashed border-gray-700">
        <i class="fa-solid fa-box-open text-4xl mb-3"></i>
        <p>База даних порожня. Додайте екіпірування!</p>
    </div>
    }
</div>

<div id="addArmorModal" class="hidden fixed inset-0 z-50 bg-black/80 flex items-center justify-center backdrop-blur-sm transition-opacity overflow-y-auto pt-10 pb-10">
    <div class="bg-panelbg border border-goldborder rounded-lg w-full max-w-3xl shadow-[0_0_30px_rgba(200,155,100,0.15)] relative my-auto">

        <div class="flex justify-between items-center p-6 border-b border-goldborder/30">
            <h2 class="text-2xl font-serif font-bold text-gray-200">
                <i class="fa-solid fa-helmet-safety text-goldtext mr-2"></i> Add New Armor
            </h2>
            <button onclick="closeModal('addArmorModal')" class="text-gray-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        <partial name="_ArmorForm" model="Model.ArmorInput" />

    </div>
</div>

<div id="addWeaponModal" class="hidden fixed inset-0 z-50 bg-black/80 flex items-center justify-center backdrop-blur-sm transition-opacity overflow-y-auto pt-10 pb-10">
    <div class="bg-panelbg border border-goldborder rounded-lg w-full max-w-3xl shadow-[0_0_30px_rgba(200,155,100,0.15)] relative my-auto">

        <div class="flex justify-between items-center p-6 border-b border-goldborder/30">
            <h2 class="text-2xl font-serif font-bold text-gray-200">
                <i class="fa-solid fa-khanda text-goldtext mr-2"></i> Add New Weapon
            </h2>
            <button onclick="closeModal('addWeaponModal')" class="text-gray-400 hover:text-white transition">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        <partial name="_WeaponForm" model="Model.WeaponInput" />

    </div>
</div>

<partial name="Shared/_EquipmentModal" model="Model" />

@section Scripts {
<script>
    // Заповнення форми броні
    function editArmor(id, name, icon, weight, poise) {
        const modal = document.getElementById('addArmorModal');

        // Змінюємо заголовок на "Edit"
        modal.querySelector('h2').innerHTML = '<i class="fa-solid fa-helmet-safety text-goldtext mr-2"></i> Edit Armor';

        // Заповнюємо основні поля (шукаємо по name, який згенерував asp-for)
        modal.querySelector('[name="Id"]').value = id;
        modal.querySelector('[name="Name"]').value = name;
        modal.querySelector('[name="IconPath"]').value = icon || '';
        // Замінюємо кому на крапку для правильного відображення десяткових чисел у JS
        modal.querySelector('[name="Weight"]').value = weight ? weight.toString().replace(',', '.') : '';
        modal.querySelector('[name="Poise"]').value = poise ? poise.toString().replace(',', '.') : '';

        openModal('addArmorModal');
    }

    // Заповнення форми зброї
    function editWeapon(id, name, icon, weight, damage, str, dex, int, fth) {
        const modal = document.getElementById('addWeaponModal');

        modal.querySelector('h2').innerHTML = '<i class="fa-solid fa-khanda text-goldtext mr-2"></i> Edit Weapon';

        modal.querySelector('[name="Id"]').value = id;
        modal.querySelector('[name="Name"]').value = name;
        modal.querySelector('[name="IconPath"]').value = icon || '';
        modal.querySelector('[name="Weight"]').value = weight ? weight.toString().replace(',', '.') : '';
        modal.querySelector('[name="Damage"]').value = damage ? damage.toString().replace(',', '.') : '';
        modal.querySelector('[name="ReqStrength"]').value = str || 0;
        modal.querySelector('[name="ReqDexterity"]').value = dex || 0;
        modal.querySelector('[name="ReqIntelligence"]').value = int || 0;
        modal.querySelector('[name="ReqFaith"]').value = fth || 0;

        openModal('addWeaponModal');
    }

    function openModal(modalId) {
        document.getElementById(modalId).classList.remove('hidden');
    }

    // Оновлений closeModal, який скидає форму при закритті
    function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        modal.classList.add('hidden');

        // Очищаємо поля, щоб при натисканні "Add" вікно було пустим
        const form = modal.querySelector('form');
        if (form) {
            form.reset();
            modal.querySelector('[name="Id"]').value = '0'; // Важливо! Скидаємо Id для створення нового запису

            // Повертаємо оригінальний заголовок
            if (modalId === 'addArmorModal') {
                modal.querySelector('h2').innerHTML = '<i class="fa-solid fa-helmet-safety text-goldtext mr-2"></i> Add New Armor';
            } else {
                modal.querySelector('h2').innerHTML = '<i class="fa-solid fa-khanda text-goldtext mr-2"></i> Add New Weapon';
            }
        }
    }
</script>
}